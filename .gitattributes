# Let Git automatically manage line endings.
# Text files are normalized to LF in the repository and checked out with the
# platform-native ending (CRLF on Windows, LF elsewhere). This keeps diffs clean
# regardless of each contributor's core.autocrlf setting.
* text=auto

#
# Source code
#
*.cs        text diff=csharp
*.csproj    text
*.props     text
*.targets   text
*.slnx      text

#
# Documentation and configuration
#
*.md        text
*.json      text
*.yml       text
*.yaml      text
*.config    text
*.editorconfig text
.gitattributes text
.gitignore  text
LICENSE     text

#
# Binary files (never normalize or diff as text)
#
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.snk       binary
*.pfx       binary
*.dll       binary
*.exe       binary
*.nupkg     binary
